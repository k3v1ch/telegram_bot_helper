# Telegram API credentials (from https://my.telegram.org)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=+7XXXXXXXXXX

# Source: group + topic to monitor (chat_id:topic_id)
SOURCE=-1003332852289:155

# Destination: where to send digest (chat_id:topic_id)
DEST=-1003332852289:220

# Groq API (https://console.groq.com/keys)
GROQ_API_KEY=

# Telegram bot (from @BotFather)
BOT_TOKEN=
ADMIN_USER_ID=

# Schedule
DIGEST_TIME=09:00
LOOKBACK_HOURS=24
WEEKLY_DIGEST_DAY=monday

# Session
SESSION_NAME=userbot

# Real-time alerts (initial state, toggleable via bot menu)
ALERTS_ENABLED=true
